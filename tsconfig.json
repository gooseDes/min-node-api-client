{
    "compilerOptions": {
        "target": "ES2019",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "declaration": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "types": ["*"],
        "paths": {
            "@/*": ["./src/*"],
        },
    },
    "include": ["src"],
}
